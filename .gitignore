# =========================
# Node / Backstage ignores
# =========================
node_modules/
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*
.yarnrc.yml.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# build outputs
dist/
build/
out/
coverage/
.tmp/
.cache/
.eslintcache
*.tsbuildinfo

# Backstage / TechDocs artifacts
site/
techdocs/
docs/site/
docs/.cache/
docs/.site/

# --- Generated artifacts (local TechDocs publish / build outputs) ---
packages/backend/static/docs/
docs/hub/_build/
.continue/

# --- Optional: compressed / index outputs (covered by static/docs/ but kept explicit) ---
**/sitemap.xml.gz
**/search_index.json
**/techdocs_metadata.json

# runtime-ish / local state
tmp/
temp/
*.pid
*.seed
*.pid.lock
*.swp
*.swo
.DS_Store

# env / secrets
.env
.env.*
!.env.example
*.local.yaml
app-config.local.yaml
app-config.*.local.yaml

# IDEs
.vscode/
.idea/
*.iml

# OS
Thumbs.db

# WSL / misc
__pycache__/
*.pyc

# backup artifacts
*.bak_*
